code = "shader_type canvas_item;
render_mode blend_mix;

uniform vec2 CenterPosition;
uniform float radius : hint_range(0, 1);
uniform float maxRadius : hint_range(0, 1);
uniform float edge : hint_range(0, 1);
uniform float intensity : hint_range(0, 50);
uniform sampler2D screen_tex_frg_15 : hint_screen_texture;



void fragment() {
// Input:4
	vec2 n_out4p0 = SCREEN_UV;


// Vector2Parameter:66
	vec2 n_out66p0 = CenterPosition;
	float n_out66p1 = n_out66p0.r;
	float n_out66p2 = n_out66p0.g;


// VectorCompose:7
	vec2 n_out7p0 = vec2(n_out66p1, n_out66p2);


// VectorOp:11
	vec2 n_out11p0 = n_out4p0 - n_out7p0;


// Input:3
	vec2 n_out3p0 = SCREEN_PIXEL_SIZE;
	float n_out3p1 = n_out3p0.r;
	float n_out3p2 = n_out3p0.g;


// FloatOp:8
	float n_out8p0 = n_out3p1 / n_out3p2;


// VectorCompose:9
	float n_in9p0 = 1.00000;
	vec2 n_out9p0 = vec2(n_in9p0, n_out8p0);


// VectorOp:10
	vec2 n_out10p0 = n_out11p0 * n_out9p0;


// VectorOp:12
	vec2 n_out12p0 = n_out10p0 + n_out7p0;


// Distance:6
	float n_out6p0 = distance(n_out12p0, n_out7p0);


// FloatParameter:16
	float n_out16p0 = radius;


// FloatParameter:64
	float n_out64p0 = maxRadius;


// FloatOp:65
	float n_out65p0 = n_out16p0 * n_out64p0;


// IntConstant:33
	int n_out33p0 = 2;


// FloatOp:34
	float n_out34p0 = n_out65p0 / float(n_out33p0);


// FloatParameter:17
	float n_out17p0 = edge;


// FloatOp:32
	float n_out32p0 = n_out17p0 / float(n_out33p0);


// Input:36
	vec2 n_out36p0 = SCREEN_UV;


// VectorOp:44
	vec2 n_out44p0 = n_out36p0 - n_out7p0;


// FloatParameter:63
	float n_out63p0 = intensity;


// FloatFunc:62
	float n_out62p0 = 1.0 - n_out16p0;


// FloatOp:61
	float n_out61p0 = n_out63p0 * n_out62p0;


// FloatOp:50
	float n_out50p0 = n_out34p0 + n_out32p0;


// FloatOp:49
	float n_out49p0 = n_out6p0 - n_out50p0;


// FloatOp:57
	float n_out57p0 = n_out61p0 * n_out49p0;


// FloatFunc:52
	float n_out52p0 = abs(n_out57p0);


// FloatOp:56
	float n_in56p0 = 1.00000;
	float n_out56p0 = n_in56p0 - n_out52p0;


// FloatOp:59
	float n_in59p1 = 0.50000;
	float n_out59p0 = pow(n_out56p0, n_in59p1);


// VectorCompose:42
	vec2 n_out42p0 = vec2(n_out59p0, n_out59p0);


// VectorOp:45
	vec2 n_out45p0 = n_out44p0 / n_out42p0;


// VectorOp:46
	vec2 n_out46p0 = n_out7p0 + n_out45p0;


	vec3 n_out14p0;
// If:14
	if(abs(n_out6p0 - n_out34p0) < n_out32p0)
	{
		n_out14p0 = vec3(n_out46p0, 0.0);
	}
	else if(n_out6p0 < n_out34p0)
	{
		n_out14p0 = vec3(n_out36p0, 0.0);
	}
	else
	{
		n_out14p0 = vec3(n_out36p0, 0.0);
	}


	vec4 n_out15p0;
// Texture2D:15
	n_out15p0 = texture(screen_tex_frg_15, vec2(n_out14p0.xy));


// Output:0
	COLOR.rgb = vec3(n_out15p0.xyz);


}
"
