code = "shader_type canvas_item;
render_mode blend_mix;

uniform float RotationSpeed;
uniform vec4 SecondaryColor : source_color;
uniform vec4 MainColor : source_color;



void fragment() {
// Input:9
	vec2 n_out9p0 = UV;
	float n_out9p1 = n_out9p0.r;
	float n_out9p2 = n_out9p0.g;


// Input:8
	float n_out8p0 = TIME;


// FloatParameter:7
	float n_out7p0 = RotationSpeed;


// FloatOp:6
	float n_out6p0 = n_out8p0 * n_out7p0;


// FloatOp:4
	float n_out4p0 = n_out9p1 + n_out6p0;


// FloatOp:3
	float n_in3p1 = 1.00000;
	float n_out3p0 = mod(n_out4p0, n_in3p1);


// VectorCompose:5
	vec2 n_out5p0 = vec2(n_out3p0, n_out9p2);


	vec4 n_out2p0;
// Texture2D:2
	n_out2p0 = texture(TEXTURE, n_out5p0);


// ColorConstant:13
	vec4 n_out13p0 = vec4(1.000000, 1.000000, 1.000000, 1.000000);


// Distance:14
	float n_out14p0 = distance(n_out2p0, n_out13p0);


// ColorParameter:11
	vec4 n_out11p0 = SecondaryColor;


// ColorParameter:10
	vec4 n_out10p0 = MainColor;


	vec3 n_out12p0;
// If:12
	float n_in12p1 = 0.00000;
	float n_in12p2 = 0.10000;
	if(abs(n_out14p0 - n_in12p1) < n_in12p2)
	{
		n_out12p0 = vec3(n_out11p0.xyz);
	}
	else if(n_out14p0 < n_in12p1)
	{
		n_out12p0 = vec3(n_out10p0.xyz);
	}
	else
	{
		n_out12p0 = vec3(n_out10p0.xyz);
	}


// Output:0
	COLOR.rgb = n_out12p0;


}
