code = "shader_type canvas_item;
render_mode blend_mix;




void fragment() {
// Input:11
	vec4 n_out11p0 = COLOR;
	float n_out11p4 = n_out11p0.a;


// Input:9
	float n_out9p0 = TIME;


// FloatConstant:4
	float n_out4p0 = 1.500000;


// FloatOp:5
	float n_out5p0 = n_out9p0 * n_out4p0;


// FloatFunc:6
	float n_out6p0 = sin(n_out5p0);


// FloatOp:3
	float n_in3p1 = 1.00000;
	float n_out3p0 = n_out6p0 + n_in3p1;


// FloatOp:7
	float n_in7p1 = 4.00000;
	float n_out7p0 = n_out3p0 / n_in7p1;


// FloatOp:12
	float n_out12p0 = n_out11p4 - n_out7p0;


// Output:0
	COLOR.a = n_out12p0;


}
