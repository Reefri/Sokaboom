code = "shader_type canvas_item;
render_mode blend_mix;

uniform float progressionGrow : hint_range(0, 1);
uniform float maxGrowth;



void vertex() {
// Input:4
	vec2 n_out4p0 = VERTEX;


// FloatParameter:2
	float n_out2p0 = progressionGrow;


// FloatParameter:7
	float n_out7p0 = maxGrowth;


// FloatOp:8
	float n_out8p0 = n_out2p0 * n_out7p0;


// FloatOp:9
	float n_in9p1 = 1.00000;
	float n_out9p0 = n_out8p0 + n_in9p1;


// VectorCompose:6
	vec2 n_out6p0 = vec2(n_out9p0, n_out9p0);


// VectorOp:5
	vec2 n_out5p0 = n_out4p0 * n_out6p0;


// Output:0
	VERTEX = n_out5p0;


}
"
