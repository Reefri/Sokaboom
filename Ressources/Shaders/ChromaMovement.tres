code = "shader_type canvas_item;
render_mode blend_mix;

uniform sampler2D tex_frg_2;



void fragment() {
// Input:10
	vec2 n_out10p0 = UV;


// FloatConstant:34
	float n_out34p0 = 0.500000;


// VectorCompose:35
	vec2 n_out35p0 = vec2(n_out34p0, n_out34p0);


// VectorOp:30
	vec2 n_out30p0 = n_out10p0 - n_out35p0;


// IntConstant:28
	int n_out28p0 = 3;


// VectorCompose:29
	vec2 n_out29p0 = vec2(float(n_out28p0), float(n_out28p0));


// VectorOp:18
	vec2 n_out18p0 = n_out30p0 / n_out29p0;


// Input:12
	float n_out12p0 = TIME;


// FloatFunc:14
	float n_out14p0 = sin(n_out12p0);


// FloatOp:15
	float n_in15p1 = 1.00000;
	float n_out15p0 = n_out14p0 + n_in15p1;


// FloatOp:16
	float n_in16p1 = 2.00000;
	float n_out16p0 = n_out15p0 / n_in16p1;


// FloatFunc:21
	float n_out21p0 = cos(n_out12p0);


// FloatOp:22
	float n_in22p1 = 1.00000;
	float n_out22p0 = n_out21p0 + n_in22p1;


// FloatOp:23
	float n_in23p1 = 2.00000;
	float n_out23p0 = n_out22p0 / n_in23p1;


// VectorCompose:33
	vec2 n_out33p0 = vec2(n_out16p0, n_out23p0);


// FloatConstant:39
	float n_out39p0 = 0.250000;


// VectorCompose:40
	vec2 n_out40p0 = vec2(n_out39p0, n_out39p0);


// VectorOp:38
	vec2 n_out38p0 = n_out33p0 * n_out40p0;


// FloatOp:9
	float n_in9p1 = 2.00000;
	float n_out9p0 = atan(n_out16p0, n_in9p1);


// FloatOp:20
	float n_in20p1 = 2.00000;
	float n_out20p0 = atan(n_out23p0, n_in20p1);


// VectorCompose:24
	vec2 n_out24p0 = vec2(n_out9p0, n_out20p0);


// VectorOp:32
	vec2 n_out32p0 = n_out38p0 * n_out24p0;


// VectorOp:31
	vec2 n_out31p0 = n_out18p0 + n_out32p0;


// VectorOp:19
	vec2 n_in19p1 = vec2(0.50000, 0.50000);
	vec2 n_out19p0 = n_out31p0 + n_in19p1;


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, n_out19p0);
	float n_out2p1 = n_out2p0.r;


// Input:3
	vec4 n_out3p0 = COLOR;


	vec3 n_out5p0;
// ColorFunc:5
	{
		vec3 c = vec3(n_out3p0.xyz);
		vec4 K = vec4(0.0, -1.0 / 3.0, 2.0 / 3.0, -1.0);
		vec4 p = mix(vec4(c.bg, K.wz), vec4(c.gb, K.xy), step(c.b, c.g));
		vec4 q = mix(vec4(p.xyw, c.r), vec4(c.r, p.yzx), step(p.x, c.r));
		float d = q.x - min(q.w, q.y);
		float e = 1.0e-10;
		n_out5p0 = vec3(abs(q.z + (q.w - q.y) / (6.0 * d + e)), d / (q.x + e), q.x);
	}
	float n_out5p1 = n_out5p0.r;
	float n_out5p2 = n_out5p0.g;
	float n_out5p3 = n_out5p0.b;


// FloatOp:25
	float n_out25p0 = n_out5p1 + n_out9p0;


// FloatOp:7
	float n_out7p0 = n_out2p1 + n_out25p0;


// VectorCompose:8
	vec3 n_out8p0 = vec3(n_out7p0, n_out5p2, n_out5p3);


	vec3 n_out6p0;
// ColorFunc:6
	{
		vec3 c = n_out8p0;
		vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
		vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
		n_out6p0 = c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
	}


// Output:0
	COLOR.rgb = n_out6p0;


}
"
