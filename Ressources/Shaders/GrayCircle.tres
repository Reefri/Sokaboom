code = "shader_type canvas_item;
render_mode blend_mix;

uniform sampler2D screen_tex_frg_3 : hint_screen_texture;
uniform float minValue : hint_range(0, 1);
uniform vec2 CenterPosition;
uniform float progression : hint_range(0, 1);
uniform float edge : hint_range(0, 1);



void fragment() {
// Input:2
	vec2 n_out2p0 = SCREEN_UV;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(screen_tex_frg_3, n_out2p0);


	vec3 n_out14p0;
// ColorFunc:14
	{
		vec3 c = vec3(n_out3p0.xyz);
		vec4 K = vec4(0.0, -1.0 / 3.0, 2.0 / 3.0, -1.0);
		vec4 p = mix(vec4(c.bg, K.wz), vec4(c.gb, K.xy), step(c.b, c.g));
		vec4 q = mix(vec4(p.xyw, c.r), vec4(c.r, p.yzx), step(p.x, c.r));
		float d = q.x - min(q.w, q.y);
		float e = 1.0e-10;
		n_out14p0 = vec3(abs(q.z + (q.w - q.y) / (6.0 * d + e)), d / (q.x + e), q.x);
	}
	float n_out14p1 = n_out14p0.r;
	float n_out14p2 = n_out14p0.g;
	float n_out14p3 = n_out14p0.b;


// FloatParameter:27
	float n_out27p0 = minValue;


// Input:12
	vec2 n_out12p0 = SCREEN_UV;


// Vector2Parameter:11
	vec2 n_out11p0 = CenterPosition;
	float n_out11p1 = n_out11p0.r;
	float n_out11p2 = n_out11p0.g;


// VectorCompose:5
	vec2 n_out5p0 = vec2(n_out11p1, n_out11p2);


// VectorOp:9
	vec2 n_out9p0 = n_out12p0 - n_out5p0;


// Input:4
	vec2 n_out4p0 = SCREEN_PIXEL_SIZE;
	float n_out4p1 = n_out4p0.r;
	float n_out4p2 = n_out4p0.g;


// FloatOp:6
	float n_out6p0 = n_out4p1 / n_out4p2;


// VectorCompose:7
	float n_in7p0 = 1.00000;
	vec2 n_out7p0 = vec2(n_in7p0, n_out6p0);


// VectorOp:8
	vec2 n_out8p0 = n_out9p0 * n_out7p0;


// VectorOp:10
	vec2 n_out10p0 = n_out8p0 + n_out5p0;


// Distance:13
	float n_out13p0 = distance(n_out10p0, n_out5p0);


// FloatConstant:38
	float n_out38p0 = 1.414214;


// FloatOp:39
	float n_in39p1 = 2.00000;
	float n_out39p0 = n_out38p0 / n_in39p1;


// FloatOp:40
	float n_out40p0 = n_out13p0 / n_out39p0;


// FloatParameter:32
	float n_out32p0 = progression;


// FloatParameter:31
	float n_out31p0 = edge;


// FloatOp:43
	float n_out43p0 = n_out32p0 + n_out31p0;


// FloatOp:42
	float n_out42p0 = n_out43p0 - n_out40p0;


// FloatOp:41
	float n_out41p0 = n_out42p0 / n_out31p0;


// FloatFunc:44
	float n_out44p0 = 1.0 - n_out41p0;


// FloatFunc:45
	float n_out45p0 = exp(n_out44p0);


// FloatOp:46
	float n_in46p1 = 1.00000;
	float n_out46p0 = n_out45p0 - n_in46p1;


// FloatFunc:48
	float n_in48p0 = 1.00000;
	float n_out48p0 = exp(n_in48p0);


// FloatOp:49
	float n_in49p1 = 1.00000;
	float n_out49p0 = n_out48p0 - n_in49p1;


// FloatOp:47
	float n_out47p0 = n_out46p0 / n_out49p0;


// FloatConstant:35
	float n_out35p0 = 1.000000;


// FloatConstant:36
	float n_out36p0 = 0.000000;


	vec3 n_out34p0;
// If:34
	if(abs(n_out40p0 - n_out43p0) < n_out31p0)
	{
		n_out34p0 = vec3(n_out47p0);
	}
	else if(n_out40p0 < n_out43p0)
	{
		n_out34p0 = vec3(n_out36p0);
	}
	else
	{
		n_out34p0 = vec3(n_out35p0);
	}


// FloatOp:28
	float n_out28p0 = n_out27p0 + n_out34p0.x;


// FloatConstant:30
	float n_out30p0 = 1.000000;


	vec3 n_out29p0;
// If:29
	float n_in29p1 = 1.00000;
	float n_in29p2 = 0.00001;
	if(abs(n_out28p0 - n_in29p1) < n_in29p2)
	{
		n_out29p0 = vec3(n_out28p0);
	}
	else if(n_out28p0 < n_in29p1)
	{
		n_out29p0 = vec3(n_out28p0);
	}
	else
	{
		n_out29p0 = vec3(n_out30p0);
	}


// FloatOp:23
	float n_out23p0 = n_out29p0.x * n_out14p2;


// VectorCompose:18
	vec3 n_out18p0 = vec3(n_out14p1, n_out23p0, n_out14p3);


	vec3 n_out15p0;
// ColorFunc:15
	{
		vec3 c = n_out18p0;
		vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
		vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
		n_out15p0 = c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
	}


// Output:0
	COLOR.rgb = n_out15p0;


}
