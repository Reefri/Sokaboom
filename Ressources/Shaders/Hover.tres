code = "shader_type canvas_item;
render_mode blend_mix;

uniform bool chromaEffect;
uniform sampler2D tex_frg_2;



void fragment() {
// BooleanParameter:31
	bool n_out31p0 = chromaEffect;


// Input:34
	vec4 n_out34p0 = COLOR;


// Input:36
	vec2 n_out36p0 = UV;


// FloatConstant:18
	float n_out18p0 = 0.500000;


// VectorCompose:21
	vec2 n_out21p0 = vec2(n_out18p0, n_out18p0);


// VectorOp:19
	vec2 n_out19p0 = n_out36p0 - n_out21p0;


// IntConstant:16
	int n_out16p0 = 3;


// VectorCompose:17
	vec2 n_out17p0 = vec2(float(n_out16p0), float(n_out16p0));


// VectorOp:11
	vec2 n_out11p0 = n_out19p0 / n_out17p0;


// Input:35
	float n_out35p0 = TIME;


// FloatFunc:8
	float n_out8p0 = sin(n_out35p0);


// FloatOp:9
	float n_in9p1 = 1.00000;
	float n_out9p0 = n_out8p0 + n_in9p1;


// FloatOp:10
	float n_in10p1 = 2.00000;
	float n_out10p0 = n_out9p0 / n_in10p1;


// FloatFunc:13
	float n_out13p0 = cos(n_out35p0);


// FloatOp:14
	float n_in14p1 = 1.00000;
	float n_out14p0 = n_out13p0 + n_in14p1;


// FloatOp:15
	float n_in15p1 = 2.00000;
	float n_out15p0 = n_out14p0 / n_in15p1;


// VectorCompose:28
	vec2 n_out28p0 = vec2(n_out10p0, n_out15p0);


// FloatConstant:30
	float n_out30p0 = 0.250000;


// VectorCompose:29
	vec2 n_out29p0 = vec2(n_out30p0, n_out30p0);


// VectorOp:27
	vec2 n_out27p0 = n_out28p0 * n_out29p0;


// FloatOp:7
	float n_in7p1 = 2.00000;
	float n_out7p0 = atan(n_out10p0, n_in7p1);


// FloatOp:12
	float n_in12p1 = 2.00000;
	float n_out12p0 = atan(n_out15p0, n_in12p1);


// VectorCompose:24
	vec2 n_out24p0 = vec2(n_out7p0, n_out12p0);


// VectorOp:26
	vec2 n_out26p0 = n_out27p0 * n_out24p0;


// VectorOp:22
	vec2 n_out22p0 = n_out11p0 + n_out26p0;


// VectorOp:23
	vec2 n_in23p1 = vec2(0.50000, 0.50000);
	vec2 n_out23p0 = n_out22p0 + n_in23p1;


// Texture2D:2
	vec4 n_out2p0 = texture(tex_frg_2, n_out23p0);
	float n_out2p1 = n_out2p0.r;


// Input:33
	vec4 n_out33p0 = COLOR;


	vec3 n_out3p0;
// ColorFunc:3
	{
		vec3 c = vec3(n_out33p0.xyz);
		vec4 K = vec4(0.0, -1.0 / 3.0, 2.0 / 3.0, -1.0);
		vec4 p = mix(vec4(c.bg, K.wz), vec4(c.gb, K.xy), step(c.b, c.g));
		vec4 q = mix(vec4(p.xyw, c.r), vec4(c.r, p.yzx), step(p.x, c.r));
		float d = q.x - min(q.w, q.y);
		float e = 1.0e-10;
		n_out3p0 = vec3(abs(q.z + (q.w - q.y) / (6.0 * d + e)), d / (q.x + e), q.x);
	}
	float n_out3p1 = n_out3p0.r;
	float n_out3p2 = n_out3p0.g;
	float n_out3p3 = n_out3p0.b;


// FloatOp:25
	float n_out25p0 = n_out3p1 + n_out7p0;


// FloatOp:5
	float n_out5p0 = n_out2p1 + n_out25p0;


// FloatConstant:38
	float n_out38p0 = 0.600000;


// FloatOp:37
	float n_out37p0 = n_out3p2 * n_out38p0;


// VectorCompose:6
	vec3 n_out6p0 = vec3(n_out5p0, n_out37p0, n_out3p3);


	vec3 n_out4p0;
// ColorFunc:4
	{
		vec3 c = n_out6p0;
		vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
		vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
		n_out4p0 = c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
	}


	vec3 n_out32p0;
// If:32
	float n_in32p1 = 0.00000;
	float n_in32p2 = 0.00001;
	if(abs((n_out31p0 ? 1.0 : 0.0) - n_in32p1) < n_in32p2)
	{
		n_out32p0 = vec3(n_out34p0.xyz);
	}
	else if((n_out31p0 ? 1.0 : 0.0) < n_in32p1)
	{
		n_out32p0 = n_out4p0;
	}
	else
	{
		n_out32p0 = n_out4p0;
	}


// Output:0
	COLOR.rgb = n_out32p0;


}
