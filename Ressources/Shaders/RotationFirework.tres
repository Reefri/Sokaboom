code = "shader_type canvas_item;
render_mode blend_mix;

uniform float RotationSpeed;



void fragment() {
// Input:3
	vec2 n_out3p0 = UV;
	float n_out3p1 = n_out3p0.r;
	float n_out3p2 = n_out3p0.g;


// Input:2
	float n_out2p0 = TIME;


// FloatParameter:14
	float n_out14p0 = RotationSpeed;


// FloatOp:13
	float n_out13p0 = n_out2p0 * n_out14p0;


// FloatOp:11
	float n_out11p0 = n_out3p1 + n_out13p0;


// FloatOp:9
	float n_in9p1 = 1.00000;
	float n_out9p0 = mod(n_out11p0, n_in9p1);


// VectorCompose:12
	vec2 n_out12p0 = vec2(n_out9p0, n_out3p2);


	vec4 n_out7p0;
// Texture2D:7
	n_out7p0 = texture(TEXTURE, n_out12p0);


// Output:0
	COLOR.rgb = vec3(n_out7p0.xyz);


}
