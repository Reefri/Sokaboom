offset_bottom = 174.0
grow_horizontal = 0
theme_override_font_sizes/font_size = 14
text = "Le personnage se dirige sur la case dans la direction de la touche pressée.
► Si la case est vide, le personnage s'y déplace
► Si une caisse est sur la case, la caisse est poussé sur la case suivante dans la direction du personnage
     et le personnage se déplace sur la case voulue.
► Si une caisse bloquée ou un mur est sur la case, le personnage ne se déplace pas
► Si une caisse bloquée ou un mur est sur la case et que le joueur a une bombe, le personnage pose la bombe sur la case et explose"

[node name="Label2" type="Label" parent="LotOfText"]
anchors_preset = -1
