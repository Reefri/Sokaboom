[internationalization]

locale/translations=PackedStringArray("res://Localisation/Localisation.en.translation", "res://Localisation/Localisation.fr.translation")

[rendering]

textures/vram_compression/import_etc2_astc=true
environment/defaults/default_clear_color=Color(0.15878, 0.0748, 0.34, 1)
